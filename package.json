{
  "name": "devnest",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "check:env": "powershell -ExecutionPolicy Bypass -File scripts/check-windows-devnest-prereqs.ps1",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "docs:dev": "npm --prefix src-webdocs run dev",
    "docs:build": "npm --prefix src-webdocs run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:fast": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && npm run build",
    "check:release": "npm run build && cargo check --manifest-path src-tauri/Cargo.toml",
    "bump:version": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bump-version.ps1",
    "release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-windows.ps1",
    "release:windows:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-windows.ps1 -AllBundles",
    "tauri": "tauri"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^7.0.0",
    "react-window": "^2.2.7",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
