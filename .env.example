# DevNest does not auto-load this file.
# Use it as a reference for local shell variables, CI secrets, or release notes.

# Official release target
DEVNEST_RELEASE_CHANNEL=stable
DEVNEST_GITHUB_REPO=hohphu8/devnest
DEVNEST_UPDATE_ENDPOINT=https://github.com/hohphu8/devnest/releases/latest/download/stable.json

# Updater signing
DEVNEST_UPDATER_KEY_PATH=C:\Users\<you>\.tauri\devnest-updater.key
DEVNEST_UPDATER_KEY_PASSWORD=
DEVNEST_UPDATER_PUBLIC_KEY=

# Optional release automation overrides
DEVNEST_RELEASE_ASSET_URL=
DEVNEST_METADATA_PUBLISH_PATH=
DEVNEST_GH_PATH=

# Optional local path overrides used by some runtime/tunnel workflows
DEVNEST_HOSTS_PATH=
DEVNEST_RUNTIME_MANIFEST_PATH=
DEVNEST_OPTIONAL_TOOL_MANIFEST_PATH=
DEVNEST_PHP_EXTENSION_MANIFEST_PATH=
DEVNEST_TUNNEL_BIN=
DEVNEST_CLOUDFLARED_CERT_PATH=
DEVNEST_CLOUDFLARED_CREDENTIALS_PATH=
DEVNEST_CLOUDFLARED_TUNNEL_ID=
